# Project Configuration
PROJECT_NAME="CleaniSense"
API_V1_STR="/api/v1"
ENVIRONMENT="production"

# Database Settings
# Required in all environments. Use PostgreSQL for Railway/production.
# DATABASE_URL="postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
DATABASE_URL="postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Firebase Admin Service Account Configuration
# Preferred for hosted deployments: paste the full Firebase service account JSON here.
# Keep GOOGLE_APPLICATION_CREDENTIALS empty unless you are running locally with a JSON file.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"YOUR_PROJECT_ID"}'
GOOGLE_APPLICATION_CREDENTIALS=""

# CORS
BACKEND_CORS_ORIGINS="https://your-vercel-app.vercel.app,http://localhost:3000"

# Gemini Vision
# Create a key in Google AI Studio and keep it server-side only.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_TIMEOUT_SECONDS=4
GEMINI_ENABLED=true

# Weather / Air Quality
# Open-Meteo requires no API key for the basic free public API.
WEATHER_PROVIDER="open-meteo"
OPEN_METEO_FORECAST_URL="https://api.open-meteo.com/v1/forecast"
OPEN_METEO_AIR_QUALITY_URL="https://air-quality-api.open-meteo.com/v1/air-quality"
WEATHER_TIMEOUT_SECONDS=4

# Hotspot Detection
HOTSPOT_RADIUS_METERS=500
HOTSPOT_MIN_COMPLAINTS=2

# Storage Backend (local | supabase | firebase)
# Production must use supabase or firebase. Local disk uploads are intentionally disabled in production.
STORAGE_BACKEND="supabase"
FIREBASE_STORAGE_BUCKET=""
UPLOAD_DIR=""
MAX_UPLOAD_SIZE_MB=10

# Supabase Storage
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_BUCKET="complaints"
