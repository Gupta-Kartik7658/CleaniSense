# Project Configuration
PROJECT_NAME="CleaniSense"
API_V1_STR="/api/v1"

# Database Settings
DATABASE_URL="sqlite:///./cleanisense.db"

# Firebase Admin Service Account Configuration
# The path to your service account JSON file relative to the backend directory
GOOGLE_APPLICATION_CREDENTIALS="firebase-service-account.json"

# Gemini Vision
# Create a key in Google AI Studio and keep it server-side only.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_TIMEOUT_SECONDS=4
GEMINI_ENABLED=true
