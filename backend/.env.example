# Project Configuration
PROJECT_NAME="CleaniSense"
API_V1_STR="/api/v1"

# Security & JWT Settings
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="change_this_to_a_very_secure_secret_key_for_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days

# Database Settings
DATABASE_URL="sqlite:///./cleanisense.db"
# For PostgreSQL: postgresql://user:password@localhost:5432/cleanisense

# External API Integrations
GEMINI_API_KEY="your-gemini-api-key-here"
OPENAQ_API_KEY="your-openaq-api-key-here"
OPEN_METEO_URL="https://api.open-meteo.com/v1"
